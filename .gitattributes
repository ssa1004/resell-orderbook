# Git attributes — 줄끝 / diff / export 관련 일관성.

# 기본: 텍스트 자동 감지 + commit 시 LF 정규화.
* text=auto eol=lf

# Java / Kotlin / 빌드 스크립트 — text 명시.
*.java   text diff=java
*.kt     text diff=kotlin
*.kts    text diff=kotlin
*.gradle text
*.xml    text
*.yml    text
*.yaml   text
*.json   text
*.md     text diff=markdown
*.properties text
*.sql    text
*.sh     text eol=lf

# Gradle wrapper jar — 바이너리.
*.jar    binary
*.class  binary
*.war    binary
*.ear    binary

# Windows 배치 / PowerShell — CRLF 유지.
*.bat    text eol=crlf
*.cmd    text eol=crlf
*.ps1    text eol=crlf

# Gradle wrapper 스크립트는 LF 고정 (실행 권한과 함께).
gradlew  text eol=lf

# 이미지 / 폰트 / 압축 — 바이너리.
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.zip    binary
*.gz     binary
*.tar    binary

# `git archive` (배포 tarball) 에서 제외할 항목 — repo 메타 / CI.
.github/         export-ignore
.gitattributes   export-ignore
.gitignore       export-ignore
.editorconfig    export-ignore
AGENTS.md        export-ignore
CONTRIBUTING.md  export-ignore
SECURITY.md      export-ignore
docs/            export-ignore
e2e-tests/       export-ignore
